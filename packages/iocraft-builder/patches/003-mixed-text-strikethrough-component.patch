# @iocraft-versions: v0.8.0
# @description: Wire strikethrough into the MixedText component
#
# Part 3 of 3 for strikethrough decoration support.
# Depends on:
#   - 001-canvas-strikethrough-field-and-render.patch (strikethrough field)
#   - 002-text-strikethrough-variant-and-component.patch (TextDecoration::Strikethrough)
#
# - Map `strikethrough:` in the MixedText component
# - Add tests for mixed strikethrough content
#
--- a/packages/iocraft/src/components/mixed_text.rs
+++ b/packages/iocraft/src/components/mixed_text.rs
@@ -157,6 +157,7 @@ impl Component for MixedText {
                     color: content.color,
                     weight: content.weight,
                     underline: content.decoration == TextDecoration::Underline,
+                    strikethrough: content.decoration == TextDecoration::Strikethrough,
                     italic: content.italic,
                 };
                 if segments.peek().is_some() {
@@ -190,4 +191,52 @@ mod tests {
             "this is a\nwrapping test\n"
         );
     }
+
+    #[test]
+    fn test_mixed_text_strikethrough() {
+        // Test strikethrough in mixed text
+        assert_eq!(
+            element! {
+                MixedText(contents: vec![
+                    MixedTextContent::new("normal "),
+                    MixedTextContent::new("strikethrough").decoration(TextDecoration::Strikethrough),
+                ])
+            }
+            .to_string(),
+            "normal strikethrough\n"
+        );
+    }
+
+    #[test]
+    fn test_mixed_text_multiple_decorations() {
+        // Test different decorations in one MixedText
+        assert_eq!(
+            element! {
+                MixedText(contents: vec![
+                    MixedTextContent::new("underlined ").decoration(TextDecoration::Underline),
+                    MixedTextContent::new("strikethrough ").decoration(TextDecoration::Strikethrough),
+                    MixedTextContent::new("none").decoration(TextDecoration::None),
+                ])
+            }
+            .to_string(),
+            "underlined strikethrough none\n"
+        );
+    }
+
+    #[test]
+    fn test_mixed_text_strikethrough_with_other_styles() {
+        // Test strikethrough combined with other text styles
+        assert_eq!(
+            element! {
+                MixedText(contents: vec![
+                    MixedTextContent::new("bold+strike")
+                        .weight(Weight::Bold)
+                        .decoration(TextDecoration::Strikethrough)
+                        .color(Color::Red),
+                ])
+            }
+            .to_string(),
+            "bold+strike\n"
+        );
+    }
 }
