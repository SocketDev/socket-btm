Socket Security: Add smol configuration structs to node_sea.h

This patch adds SmolUpdateConfig and SmolVfsConfig struct definitions
to the SEA header, enabling smol configuration support.

Files modified:
- src/node_sea.h: Add SmolUpdateConfig and SmolVfsConfig structs

--- a/src/node_sea.h
+++ b/src/node_sea.h
@@ -37,6 +37,25 @@
   kCli = 2,
 };

+struct SmolUpdateConfig {
+  std::string binname;
+  std::string command;
+  std::string url;
+  std::string tag;
+  std::string skip_env;
+  std::string fake_argv_env;
+  bool prompt = false;
+  char prompt_default = 'n';
+  int64_t interval = 86400000;        // 24 hours in ms
+  int64_t notify_interval = 86400000; // 24 hours in ms
+};
+
+struct SmolVfsConfig {
+  std::string mode;   // "on-disk", "in-memory", "compat"
+  std::string source; // path to .tar, .tar.gz, or directory
+  std::string prefix; // VFS path prefix, e.g., "/snapshot"
+};
+
 struct SeaConfig {
   std::string main_path;
   std::string output_path;
@@ -45,6 +64,10 @@
   SeaExecArgvExtension exec_argv_extension = SeaExecArgvExtension::kEnv;
   std::unordered_map<std::string, std::string> assets;
   std::vector<std::string> exec_argv;
+  // Socket Security: smol extensions
+  std::optional<std::string> smol_stub_path;
+  std::optional<SmolVfsConfig> smol_vfs;
+  std::optional<SmolUpdateConfig> smol_update;
 };

 struct SeaResource {
