 def configure_node_lib_files(o):
-  o['variables']['node_library_files'] = SearchFiles('lib', 'js')
+  files = SearchFiles('lib', 'js')
+
+  # Socket Security: when a smol subsystem is trimmed out (its native binding
+  # gated off the build), also drop its JS wrapper(s) from the builtins snapshot.
+  # Otherwise the wrapper stays a builtin — isBuiltin('node:smol-X') reports
+  # true and require() loads a wrapper whose native binding is gone. Gating the
+  # wrapper here keeps the trim honest: a dropped feature is simply not a builtin.
+  #
+  # Declarative map: (disabled?, [lib/ path stems to remove]). A stem matches the
+  # wrapper file `lib/<stem>.js` AND any subpath module under `lib/<stem>/`
+  # (e.g. smol-ffi → smol-ffi.js + smol-ffi/{node,bun}.js). Only gated subsystems
+  # appear here; always-on wrappers (smol-util/power/primordial/vfs/versions/
+  # manifest/purl/sql/webgpu/https) are never dropped. Keep in lockstep with the
+  # node_use_smol_* gyp gates in node.gyp (patches 004/018).
+  use_smol_quic = not bool(options.without_smol_quic) and not bool(options.without_ssl)
+  smol_wrapper_gates = [
+    (not use_smol_quic,                      ['smol-quic']),
+    (bool(options.without_smol_http),        ['smol-http']),
+    (bool(options.without_smol_tui),         ['smol-tui']),
+    (bool(options.without_smol_keychain),    ['smol-keychain']),
+    (bool(options.without_smol_keymap),      ['smol-keymap']),
+    (bool(options.without_smol_ffi),         ['smol-ffi']),
+    (bool(options.without_smol_ilp),         ['smol-ilp']),
+    (bool(options.without_smol_treesitter),  ['smol-tree-sitter']),
+    (bool(options.without_smol_qrcode),      ['smol-qrcode']),
+    (bool(options.without_smol_markdown),    ['smol-markdown']),
+  ]
+  drop_stems = []
+  for disabled, stems in smol_wrapper_gates:
+    if disabled:
+      drop_stems += stems
+  if drop_stems:
+    def keep(path):
+      # path is POSIX 'lib/...'; drop 'lib/<stem>.js' and 'lib/<stem>/...'.
+      for stem in drop_stems:
+        if path == 'lib/' + stem + '.js' or path.startswith('lib/' + stem + '/'):
+          return False
+      return True
+    files = [f for f in files if keep(f)]
+
+  o['variables']['node_library_files'] = files
 
