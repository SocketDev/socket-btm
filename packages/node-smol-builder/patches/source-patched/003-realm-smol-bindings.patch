# @node-versions: v26.1.0
# @description: Register smol_vfs binding and smol modules in realm
#
# This patch:
# 1. Adds smol_vfs to the process binding allow list in the bootstrap realm,
#    enabling VFS (Virtual File System) functionality for single executable
#    applications.
# 2. Adds every smol-* module to schemelessBlockList so each requires the
#    node: prefix (e.g. node:smol-http instead of smol-http).
#    Includes the smol-ffi/node and smol-ffi/bun compat subpaths so they
#    can only be loaded as `node:smol-ffi/node` / `node:smol-ffi/bun`,
#    mirroring the schemelessness of the parent `smol-ffi` module.
#
# Files modified:
# - lib/internal/bootstrap/realm.js: smol_vfs binding + smol-* schemelessBlockList
#
--- a/lib/internal/bootstrap/realm.js
+++ b/lib/internal/bootstrap/realm.js
@@ -101,6 +101,7 @@
   'os',
   'pipe_wrap',
   'process_wrap',
+  'smol_vfs',
   'spawn_sync',
   'stream_wrap',
   'tcp_wrap',
@@ -127,6 +128,25 @@
   'ffi',
   'sea',
   'sqlite',
+  'smol-ffi',
+  'smol-ffi/bun',
+  'smol-ffi/node',
+  'smol-http',
+  'smol-https',
+  'smol-ilp',
+  'smol-manifest',
+  'smol-markdown',
+  'smol-power',
+  'smol-primordial',
+  'smol-purl',
+  'smol-quic',
+  'smol-sql',
+  'smol-tree-sitter',
+  'smol-tui',
+  'smol-util',
+  'smol-vfs',
+  'smol-versions',
+  'smol-webgpu',
   'quic',
   'test',
   'test/reporters',
