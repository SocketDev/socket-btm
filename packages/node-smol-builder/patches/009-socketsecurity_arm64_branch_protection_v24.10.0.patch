# @node-versions: v24+
# @description: Enable ARM64 branch protection
#
# Enable branch protection for ARM64 builds on macOS and Linux.
# Provides pointer authentication (PAC) to prevent branch hijacking attacks.
#
# This matches official Node.js ARM64 configuration.

--- a/common.gypi
+++ b/common.gypi
@@ -233,6 +233,10 @@
             # frames otherwise, even with --call-graph dwarf.
             'cflags': [ '-fno-omit-frame-pointer' ],
           }],
+        # ARM64 branch protection (pointer authentication)
+        ['target_arch=="arm64" and OS!="win"', {
+          'cflags': [ '-mbranch-protection=standard' ],
+        }],
           ['OS=="linux" or OS=="openharmony"', {
             'conditions': [
               ['enable_pgo_generate=="true"', {
