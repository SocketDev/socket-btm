# @node-versions: v25.9.0
# @description: Wire smol-util native source into node.gyp
#
# Adds src/socketsecurity/util/util_binding.cc to the main node target.
# Unlike smol-power (5 platform-specific files), smol-util is a single
# platform-agnostic file — it's pure V8 binding glue with no
# OS-specific syscalls.
#
# Sequencing: 030 anchors after 026 (smol-power node-gyp). The hunk
# inserts the util block immediately after the power block so the
# patches compose linearly.
#
# Files modified:
# - node.gyp: add smol-util binding source
#
--- a/node.gyp
+++ b/node.gyp
@@ -1,4 +1,11 @@
         ['OS=="win"', {
           'sources': [ 'src/socketsecurity/power/power_win.cc' ],
         }],
+        # Socket Security: smol-util binding. Pure V8 glue, no
+        # platform-specific code — compiles on every OS.
+        ['1==1', {
+          'sources': [
+            'src/socketsecurity/util/util_binding.cc',
+          ],
+        }],
         ['node_with_ltcg=="true"', {
