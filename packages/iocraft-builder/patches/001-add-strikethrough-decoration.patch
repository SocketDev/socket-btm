+    #[test]
+    fn test_text_strikethrough_decoration() {
+        // Test strikethrough renders correctly to plain text
+        assert_eq!(
+            element!(Text(content: "strikethrough", decoration: TextDecoration::Strikethrough))
+                .to_string(),
+            "strikethrough\n"
+        );
+    }
+
+    #[test]
+    fn test_text_strikethrough_ansi_output() {
+        // Test that strikethrough produces ANSI output
+        let output = element! {
+            Text(content: "test", decoration: TextDecoration::Strikethrough)
+        }
+        .to_string();
+
+        // Basic assertion that it produces output with the text
+        assert!(output.len() > 0);
+        assert!(output.trim().len() >= 4); // At least contains "test"
+    }
+
+    #[test]
+    fn test_text_strikethrough_with_alignment() {
+        // Test that strikethrough works with text alignment
+        let output = element! {
+            View(width: 10) {
+                Text(content: "test", align: TextAlign::Center, decoration: TextDecoration::Strikethrough)
+            }
+        }
+        .to_string();
+
+        // Should contain the text
+        assert!(output.contains("test"));
+    }
