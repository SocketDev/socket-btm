{
  "name": "boringssl-builder",
  "version": "0.0.0",
  "description": "Builds BoringSSL static libs (prefixed: BORINGSSL_PREFIX=smol) for lsquic + uWebSockets consumption",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./lib/ensure-boringssl": "./lib/ensure-boringssl.mts"
  },
  "scripts": {
    "build": "node scripts/build.mts",
    "clean": "node scripts/clean.mts",
    "cover": "vitest run --coverage",
    "test": "vitest run"
  },
  "dependencies": {
    "@socketsecurity/lib-stable": "catalog:",
    "build-infra": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  }
}
