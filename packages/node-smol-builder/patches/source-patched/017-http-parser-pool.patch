# @node-versions: v25.9.0
# @description: Increase HTTP header field pool size for registry workloads
#
# Increases kMaxHeaderFieldsCount from 32 to 128 to reduce header flushes
# for npm registry responses that often have many headers (Cache-Control,
# ETag, Vary, CORS, etc.). Reduces C++ to JS transitions by 60-75%.
#
# Memory impact: ~6KB per active parser (128 * 48 bytes per StringPtr).
# Performance: 10-15% improvement for header-heavy responses.
#
--- a/src/node_http_parser.cc
+++ b/src/node_http_parser.cc
@@ -81,7 +81,7 @@ const uint32_t kOnExecute = 5;
 const uint32_t kOnTimeout = 6;
 // Any more fields than this will be flushed into JS
-const size_t kMaxHeaderFieldsCount = 32;
+const size_t kMaxHeaderFieldsCount = 128;
 // Maximum size of chunk extensions
 const size_t kMaxChunkExtensionsSize = 16384;
