{
  "name": "@node-smol/ai.node-darwin-arm64",
  "version": "0.0.0",
  "description": "Native node:smol-ai backend for Darwin arm64",
  "license": "MIT",
  "files": [
    "smol_ai.node"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "type": "commonjs",
  "main": "./smol_ai.node",
  "exports": {
    ".": "./smol_ai.node"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepublishOnly": "node -e \"const fs=require('node:fs');if(!process.env.NODE_SMOL_PUBLISH_OK||!fs.existsSync('smol_ai.node'))process.exit(1)\""
  },
  "preferUnpacked": true
}
