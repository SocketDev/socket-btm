# @node-versions: v25.9.0, v26.0.0
# @description: Wire smol-power native sources + IOKit framework into node.gyp
#
# Adds the smol-power binding sources to the main node target. The
# binding glue (power_binding.cc) is platform-agnostic and always
# compiled; the per-OS implementations (power_mac.cc / power_linux.cc /
# power_win.cc) are gated on OS so each build only pulls in the one
# that compiles.
#
# macOS additionally links IOKit.framework (CoreFoundation is already
# linked by the base node.gyp).
#
# Sequencing: anchored on the `<(node_core_target_name)` target's
# OS=="mac" -lcompression block (the first of three identical clusters
# in node.gyp). 026 must apply after 004-node-gyp-smol-sources.patch
# which adds that block.
#
# Files modified:
# - node.gyp: add smol-power sources + IOKit framework (in <(node_core_target_name))
#
--- a/node.gyp
+++ b/node.gyp
@@ -737,7 +737,27 @@
         ['OS=="mac"', {
           'libraries': [
             '-lcompression',
+          ],
+        }],
+        # Socket Security: smol-power binding sources. The platform-
+        # agnostic V8 glue (power_binding.cc) compiles on every OS;
+        # each per-OS impl compiles only on its target so platform
+        # headers (<IOKit/...>, <windows.h>, <dirent.h>) stay
+        # isolated.
+        ['1==1', {
+          'sources': [
+            'src/socketsecurity/power/power_binding.cc',
           ],
+        }],
+        ['OS=="mac"', {
+          'libraries': [ '-framework IOKit' ],
+          'sources': [ 'src/socketsecurity/power/power_mac.cc' ],
+        }],
+        ['OS=="linux"', {
+          'sources': [ 'src/socketsecurity/power/power_linux.cc' ],
+        }],
+        ['OS=="win"', {
+          'sources': [ 'src/socketsecurity/power/power_win.cc' ],
         }],
         ['node_with_ltcg=="true"', {
           'msvs_settings': {
