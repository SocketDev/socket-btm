# @node-versions: v24.10.0+
# @description: Fix v8_inspector_headers for cross-compilation
# @phase: 1
#
# This patch fixes "multiple rules generate" ninja errors when cross-compiling
# by making v8_inspector_headers actions run only on the host toolset.
#
# Error without this patch:
#   ninja: error: obj.host/tools/v8_gypfiles/v8_inspector_headers.ninja:14:
#   multiple rules generate gen/inspector-generated-output-root/src/js_protocol.stamp
#
# Root cause: When cross-compiling, v8_inspector_headers has toolsets: ['host', 'target']
# and actions that generate files. GYP tries to run the actions twice (once for each
# toolset), creating duplicate build rules for the same output files.
#
# Solution: Keep v8_inspector_headers available for both toolsets (so dependencies resolve),
# but make the actions conditional to only run on 'host'. The generated header files are
# placed in SHARED_INTERMEDIATE_DIR and used by both host and target builds.

--- a/tools/v8_gypfiles/v8.gyp
+++ b/tools/v8_gypfiles/v8.gyp
@@ -109,6 +109,7 @@
       'actions': [
         {
           'action_name': 'protocol_compatibility',
+          'toolsets': ['host'],
           'inputs': [
             '<(v8_inspector_js_protocol)',
           ],
@@ -125,6 +126,7 @@
         },
         {
           'action_name': 'protocol_generated_sources',
+          'toolsets': ['host'],
           'inputs': [
             '<(v8_inspector_js_protocol)',
             '<(inspector_path)/inspector_protocol_config.json',
