+              ['node_section_ordering_info==""', {
+                # Identical Code Folding: link with gold and fold byte-identical
+                # functions. --icf=safe keeps function-pointer identity intact
+                # (V8 compares code pointers), so only address-insensitive
+                # functions are merged. -ffunction-sections gives the linker
+                # per-function granularity to fold. Skipped when section
+                # ordering is active, which already pulls in gold itself.
+                'cflags': [
+                  '-fuse-ld=gold',
+                  '-ffunction-sections',
+                ],
+                'ldflags': [
+                  '-fuse-ld=gold',
+                  '-Wl,--icf=safe',
+                ],
+              }],
             ],
           }],
