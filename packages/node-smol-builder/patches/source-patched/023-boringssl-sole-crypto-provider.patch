# @node-versions: v26.1.0
# @description: Make BoringSSL the sole crypto provider (drop bundled OpenSSL)
#
# node-smol uses BoringSSL (built -DBORINGSSL_PREFIX=smol) as its crypto/TLS
# provider — node::crypto compiles the OPENSSL_IS_BORINGSSL code paths and links
# libsmol_{ssl,crypto,decrepit}.a via deps/boringssl/boringssl.gyp's
# link_settings (reached through libnode's boringssl dependency + ncrypto, see
# patches 004 + 022).
#
# But node.gypi's `node_use_openssl=="true" && node_shared_openssl=="false"`
# block ALSO built and -force_load'ed the upstream bundled OpenSSL
# (deps/openssl/openssl.gyp:openssl → libopenssl.a). Linking both providers
# produced duplicate symbols at node_mksnapshot link time — BoringSSL exports a
# handful of digest constructors UNPREFIXED (EVP_sha3_224/256/384/512,
# EVP_sha512_224, EVP_blake2b512, EVP_ripemd160) which collide with bundled
# OpenSSL's same symbols.
#
# Drop the bundled-openssl dependency (openssl + openssl-cli) and its
# -force_load / --whole-archive / openssl.def wiring from that block, leaving
# BoringSSL as the single crypto provider. HAVE_OPENSSL=1 and OPENSSL_API_COMPAT
# are kept (crypto sources still compile against the BoringSSL headers). The
# bundled openssl-cli was only referenced by the node_fipsinstall action, which
# is gated off (openssl_is_fips=false).
#
--- a/node.gypi
+++ b/node.gypi
@@ -394,48 +394,19 @@
       'defines': [ 'HAVE_OPENSSL=1' ],
       'conditions': [
         [ 'node_shared_openssl=="false"', {
+          # Socket Security: node-smol uses BoringSSL (smol_-prefixed) as its SOLE
+          # crypto/TLS provider — node::crypto compiles the OPENSSL_IS_BORINGSSL
+          # paths and links libsmol_{ssl,crypto,decrepit}.a via
+          # deps/boringssl/boringssl.gyp's link_settings (pulled in through the
+          # libnode `boringssl` dependency + ncrypto, patches 004/022). The
+          # upstream bundled OpenSSL (deps/openssl) is NOT built or linked here:
+          # force_load'ing libopenssl.a alongside BoringSSL produced duplicate
+          # symbols (EVP_sha3_*, EVP_blake2b512, EVP_ripemd160 — BoringSSL exports
+          # a handful of digest constructors unprefixed). Dropping the bundled
+          # openssl dep + its -force_load/whole-archive wiring leaves BoringSSL as
+          # the single provider. OPENSSL_API_COMPAT is kept (harmless define
+          # referenced by crypto sources).
           'defines': [ 'OPENSSL_API_COMPAT=0x10100000L', ],
-          'dependencies': [
-            './deps/openssl/openssl.gyp:openssl',
-
-            # For tests
-            './deps/openssl/openssl.gyp:openssl-cli',
-          ],
-          'conditions': [
-            # -force_load or --whole-archive are not applicable for
-            # the static library
-            [ 'force_load=="true"', {
-              'xcode_settings': {
-                'OTHER_LDFLAGS': [
-                  '-Wl,-force_load,<(PRODUCT_DIR)/<(openssl_product)',
-                ],
-              },
-              'msvs_settings': {
-                'VCLinkerTool': {
-                  'AdditionalOptions': [
-                    '/WHOLEARCHIVE:<(PRODUCT_DIR)/lib/<(openssl_product)',
-                  ],
-                },
-              },
-              'conditions': [
-                ['OS in "linux freebsd openharmony" and node_shared=="false"', {
-                  'ldflags': [
-                    '-Wl,--whole-archive',
-                      '<(obj_dir)/deps/openssl/<(openssl_product)',
-                    '-Wl,--no-whole-archive',
-                  ],
-                }],
-                # openssl.def is based on zlib.def, zlib symbols
-                # are always exported.
-                ['use_openssl_def==1', {
-                  'sources': ['<(SHARED_INTERMEDIATE_DIR)/openssl.def'],
-                }],
-                ['OS=="win" and use_openssl_def==0', {
-                  'sources': ['deps/zlib/win32/zlib.def'],
-                }],
-              ],
-            }],
-          ]
         }],
       ]
     }, {
