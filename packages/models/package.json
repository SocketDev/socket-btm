{
  "name": "models",
  "version": "0.0.0",
  "description": "AI models for Socket CLI (MiniLM-L6, CodeT5)",
  "type": "module",
  "private": true,
  "exports": {
    "./dist/minilm-l6.onnx": "./dist/minilm-l6.onnx",
    "./dist/minilm-l6-tokenizer.json": "./dist/minilm-l6-tokenizer.json",
    "./dist/codet5-encoder.onnx": "./dist/codet5-encoder.onnx",
    "./dist/codet5-decoder.onnx": "./dist/codet5-decoder.onnx",
    "./dist/codet5-tokenizer.json": "./dist/codet5-tokenizer.json"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:minilm": "node scripts/build.mjs --minilm",
    "build:codet5": "node scripts/build.mjs --codet5",
    "build:force": "node scripts/build.mjs --force",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "build-infra": "workspace:*",
    "@socketsecurity/lib": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  },
  "externalTools": {
    "torch": {
      "description": "PyTorch machine learning framework",
      "type": "python",
      "versions": {
        "pip": "2.5.1"
      }
    },
    "transformers": {
      "description": "HuggingFace Transformers library for NLP models",
      "type": "python",
      "versions": {
        "pip": "4.46.3"
      }
    },
    "optimum": {
      "description": "HuggingFace Optimum library for model optimization",
      "type": "python",
      "versions": {
        "pip": "1.23.3"
      },
      "extras": ["exporters"]
    },
    "onnx": {
      "description": "ONNX (Open Neural Network Exchange) format library",
      "type": "python",
      "versions": {
        "pip": "1.17.0"
      }
    },
    "onnxruntime": {
      "description": "ONNX Runtime inference engine",
      "type": "python",
      "versions": {
        "pip": "1.21.0"
      }
    },
    "onnxscript": {
      "description": "ONNX Script for ONNX model authoring",
      "type": "python",
      "versions": {
        "pip": "0.1.0"
      }
    },
    "huggingface_hub": {
      "description": "HuggingFace Hub client library",
      "type": "python",
      "versions": {
        "pip": "0.26.5"
      }
    },
    "sentence_transformers": {
      "description": "Sentence Transformers for sentence embeddings",
      "type": "python",
      "versions": {
        "pip": "3.3.1"
      }
    }
  }
}
