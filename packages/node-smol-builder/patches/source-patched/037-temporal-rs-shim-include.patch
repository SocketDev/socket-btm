# @node-versions: v26.1.0
# @description: Replace V8's temporal_rs Rust dependency with socket-btm C++ shim
#
# V8's js-temporal-objects.cc #includes `temporal_rs/*.hpp`, which
# upstream resolves through a header set shipped by the Rust crate
# `temporal_capi` at deps/crates/vendor/temporal_capi/bindings/cpp/.
# Building those headers requires rustc + cargo + ICU4X data crates
# (~50 transitive deps, ~5 minute cold build).
#
# socket-btm ships a hand-written C++ port of temporal_capi (the
# `temporal-infra` package) plus a drop-in shim layer at
# packages/temporal-infra/include/temporal_rs/ that has the same
# `temporal_rs::*` surface V8 expects but routes everything to the
# C++ port instead of through diplomat/FFI to Rust.
#
# This patch reshapes the `temporal_capi` gyp target so it:
#
# 1. Drops the rustc/cargo dependency (`node_crates`) — no Rust build.
# 2. Repoints the include path from the Rust-generated bindings dir
#    (`<(cargo_vendor_dir)/temporal_capi/bindings/cpp`) to
#    `../../include` + `../../src` (i.e. Node-source-root-relative paths
#    that, after copy-additions.mts populates them from
#    packages/temporal-infra/include/temporal_rs/ +
#    packages/temporal-infra/src/socketsecurity/temporal/, give V8
#    the shim headers and the C++ port headers).
# 3. Compiles the temporal-infra `.cc` files directly into a
#    `static_library` produced by this target, so V8's
#    `v8_base_without_compiler` (which depends on `:temporal_capi`) and
#    `mksnapshot` (which links a subset of v8_base) both get the
#    `node::socketsecurity::temporal::*` symbols at link time. Without
#    this, mksnapshot's link fails with "undefined reference to
#    node::socketsecurity::temporal::*" because libnode isn't part of
#    the snapshot tool.
#
# The C++ port files are listed by name (24 files in temporal-infra/src/
# socketsecurity/temporal/) rather than glob to keep the dependency
# manifest explicit. Update both this patch and patch 004 in lockstep
# when adding/removing port files.
#
# Files modified:
# - deps/crates/crates.gyp: temporal_capi target compiles shim + port
#
--- a/deps/crates/crates.gyp
+++ b/deps/crates/crates.gyp
@@ -112,15 +112,44 @@
     },
     {
       'target_name': 'temporal_capi',
-      'type': 'none',
+      'type': 'static_library',
       'toolsets': ['host', 'target'],
-      'sources': [],
-      'dependencies': [
-        'node_crates',
+      'sources': [
+        # Socket-btm C++ port of boa-dev/temporal. Headers are in
+        # `<src_root>/include/temporal_rs/` (diplomat-shaped shim) and
+        # `<src_root>/src/socketsecurity/temporal/` (port headers); the
+        # corresponding .cc files live alongside the port headers.
+        '../../src/socketsecurity/temporal/calendar.cc',
+        '../../src/socketsecurity/temporal/duration_normalized.cc',
+        '../../src/socketsecurity/temporal/duration.cc',
+        '../../src/socketsecurity/temporal/error.cc',
+        '../../src/socketsecurity/temporal/host.cc',
+        '../../src/socketsecurity/temporal/instant.cc',
+        '../../src/socketsecurity/temporal/iso.cc',
+        '../../src/socketsecurity/temporal/now.cc',
+        '../../src/socketsecurity/temporal/options.cc',
+        '../../src/socketsecurity/temporal/parse.cc',
+        '../../src/socketsecurity/temporal/parsed_intermediates.cc',
+        '../../src/socketsecurity/temporal/plain_date_time.cc',
+        '../../src/socketsecurity/temporal/plain_date.cc',
+        '../../src/socketsecurity/temporal/plain_month_day.cc',
+        '../../src/socketsecurity/temporal/plain_time.cc',
+        '../../src/socketsecurity/temporal/plain_year_month.cc',
+        '../../src/socketsecurity/temporal/primitive.cc',
+        '../../src/socketsecurity/temporal/relative_to.cc',
+        '../../src/socketsecurity/temporal/sys.cc',
+        '../../src/socketsecurity/temporal/time_zone.cc',
+        '../../src/socketsecurity/temporal/utils.cc',
+        '../../src/socketsecurity/temporal/zoned_date_time.cc',
       ],
+      'include_dirs': [
+        '../../include',
+        '../../src',
+      ],
       'direct_dependent_settings': {
         'include_dirs': [
-          '<(cargo_vendor_dir)/temporal_capi/bindings/cpp',
+          '../../include',
+          '../../src',
         ],
       },
     },
