# @node-versions: v25.9.0
# @description: Add smol_versions_native to external reference list
#
# Adds V(smol_versions_native) to EXTERNAL_REFERENCE_BINDING_LIST so
# the binding's externally-referenced functions are registered during
# V8 snapshot building. Required for any binding that calls
# NODE_BINDING_EXTERNAL_REFERENCE() — smol_versions_native does.
#
# Sequencing: 036 anchors after 033 (smol_primordial external-refs).
# Insert keeps alphabetic order: smol_primordial < smol_util <
# smol_versions_native < smol_vfs (note the post-position because
# `versions_n` < `vfs` lexically).
#
# Files modified:
# - src/node_external_reference.h: register smol_versions_native
#
--- a/src/node_external_reference.h
+++ b/src/node_external_reference.h
@@ -161,2 +161,3 @@
   V(smol_util)                                                                 \
+  V(smol_versions_native)                                                      \
   V(smol_vfs)                                                                  \
