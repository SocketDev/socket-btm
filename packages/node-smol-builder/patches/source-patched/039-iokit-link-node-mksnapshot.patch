# @node-versions: v26.1.0
# @description: Link IOKit.framework in node_mksnapshot for power_mac.cc
#
# `node_mksnapshot` (a Node-side snapshot tool, distinct from V8's
# `mksnapshot`) is an executable that links `<(node_lib_target_name)`
# (= libnode.a). libnode.a contains `power_mac.cc`, which calls
# `IOPSGetPowerSourceDescription` from Apple's IOKit.framework.
#
# Patch 004 already applies `-framework IOKit` to the libnode_base
# target via gyp's `'libraries'` list, but that does NOT propagate to
# executables that depend on the static lib — gyp only forwards
# `link_settings.libraries`, not `libraries`, from a `static_library`
# to its consumers. So node_mksnapshot's link command has all of
# libnode.a's symbols but no `-framework IOKit` flag, which manifests
# as:
#
#   Undefined symbols for architecture x86_64:
#     "_IOPSGetPowerSourceDescription", referenced from:
#         node::socketsecurity::power::IsOnAcPowerImpl()
#           in libnode.a[223](libnode.power_mac.o)
#   ld: symbol(s) not found for architecture x86_64
#
# Mirror the framework link directly on `node_mksnapshot` so the
# linker has both the symbols (from libnode.a) and the framework
# (from this target's own `libraries`). Per the rule about avoiding
# refactors during a fix: the cleaner long-term approach would be to
# rewrite patch 004's libnode `libraries` block as `link_settings`,
# but that requires rewriting downstream hunk offsets in patch 004 —
# riskier than this surgical add-only patch.
#
# Files modified:
# - node.gyp: node_mksnapshot target gets -framework IOKit on macOS
#
--- a/node.gyp
+++ b/node.gyp
@@ -1744,6 +1744,15 @@
             'Ws2_32.lib',
           ],
         }],
+        # Socket Security: node_mksnapshot links libnode.a, which contains
+        # power_mac.cc's IOPSGetPowerSourceDescription call into Apple's
+        # IOKit framework. Static-libs don't forward 'libraries' to
+        # consumers in gyp, so we mirror the framework link here.
+        ['OS=="mac"', {
+          'libraries': [
+            '-framework IOKit',
+          ],
+        }],
         # Avoid excessive LTO
         ['enable_lto=="true"', {
           'ldflags': [ '-fno-lto' ],
