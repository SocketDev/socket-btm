{
  "name": "@node-smol/ai.node-linux-arm64-musl",
  "version": "0.0.0",
  "description": "Native node:smol-ai backend for Linux arm64 musl",
  "license": "MIT",
  "files": [
    "build/smol_ai.node"
  ],
  "os": [
    "linux"
  ],
  "cpu": [
    "arm64"
  ],
  "libc": [
    "musl"
  ],
  "type": "commonjs",
  "main": "./build/smol_ai.node",
  "exports": {
    ".": "./build/smol_ai.node"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepublishOnly": "node -e \"const fs=require('node:fs');if(!process.env.NODE_SMOL_PUBLISH_OK||!fs.existsSync('build/smol_ai.node'))process.exit(1)\""
  },
  "preferUnpacked": true
}
