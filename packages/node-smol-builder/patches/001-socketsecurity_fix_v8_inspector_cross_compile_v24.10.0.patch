++                "<(SHARED_INTERMEDIATE_DIR)/torque-generated/factory.cc",
++                "<(SHARED_INTERMEDIATE_DIR)/torque-generated/factory.inc",
++                "<(SHARED_INTERMEDIATE_DIR)/torque-generated/instance-types.h",
