# @node-versions: v26.1.0
# @description: Add --with-postgres/--with-iouring/--with-{node,smol}-quic/--with-smol-http3/--without-smol-tui configure options + drop cargo gate
#
# Adds configure options for building Node.js with PostgreSQL support
# and optional io_uring acceleration (both disabled by default).
# PostgreSQL requires libpq bundled in deps/libpq; io_uring is Linux-only
# and requires liburing.
#
# Adds three QUIC/HTTP3 toggles replacing the single --experimental-quic
# switch:
#
#   --with-node-quic     (default false): upstream's ngtcp2 stack +
#                                         node:quic builtin.
#   --with-smol-quic     (default true):  socket-btm's lsquic stack +
#                                         node:smol-quic builtin.
#   --with-smol-http3    (default true):  http3 binding glue +
#                                         node:smol-http3 builtin
#                                         (depends on smol-quic).
#
# Implication rules: --without-smol-quic with --with-smol-http3 errors;
# --without-ssl forces all three off; --experimental-quic stays as a
# back-compat alias for --with-node-quic.
#
# Adds --without-smol-tui (default enabled) gating the tui-infra C++ port
# + Yoga 3.2.1 layout engine + node:smol-tui builtin. When disabled the
# tui sources and Yoga sources are excluded from the build graph and the
# binding is not registered.
#
# Also disables the upstream cargo/rustc gate — Temporal is provided via
# the C++ shim in temporal-infra, so the build does not need a Rust
# toolchain.
#
--- a/configure.py
+++ b/configure.py
@@ -1058,11 +1058,47 @@
     dest='without_ffi',
     default=None,
     help='build without FFI (Foreign Function Interface) support')
+
+parser.add_argument('--with-postgres',
+    action='store_true',
+    dest='with_postgres',
+    default=None,
+    help='build with PostgreSQL (enables PostgreSQL in node:sql API, requires libpq)')
 
+parser.add_argument('--with-iouring',
+    action='store_true',
+    dest='with_iouring',
+    default=None,
+    help='build with io_uring support (Linux only, requires liburing)')
+
 parser.add_argument('--experimental-quic',
     action='store_true',
     dest='experimental_quic',
     default=None,
-    help='build with experimental QUIC support')
+    help='alias for --with-node-quic (upstream ngtcp2 QUIC)')
+
+parser.add_argument('--with-node-quic',
+    action='store_true',
+    dest='with_node_quic',
+    default=None,
+    help='build upstream Node QUIC (ngtcp2 + node:quic, default off)')
+
+parser.add_argument('--without-smol-quic',
+    action='store_true',
+    dest='without_smol_quic',
+    default=None,
+    help='disable socket-btm lsquic + node:smol-quic (default enabled)')
+
+parser.add_argument('--without-smol-http3',
+    action='store_true',
+    dest='without_smol_http3',
+    default=None,
+    help='disable socket-btm http3 + node:smol-http3 (default enabled)')
+
+parser.add_argument('--without-smol-tui',
+    action='store_true',
+    dest='without_smol_tui',
+    default=None,
+    help='disable tui-infra + Yoga + node:smol-tui (default enabled)')
 
 parser.add_argument('--ninja',
@@ -1576,8 +1594,8 @@
 
   o['variables']['llvm_version'] = get_llvm_version(CC) if is_clang else '0.0'
 
-  # cargo and rustc are needed for Temporal.
-  if not options.v8_disable_temporal_support and not options.shared_temporal_capi:
+  # cargo/rustc gate disabled — Temporal backed by temporal-infra C++ shim (patches 004 + 021).
+  if False:
     # Minimum cargo and rustc versions should match values in BUILDING.md.
     min_cargo_ver_tuple = (1, 82)
     min_rustc_ver_tuple = (1, 82)
@@ -2345,7 +2363,44 @@
     return
 
   configure_library('ffi', o, pkgname='libffi')
+
+def configure_postgres(o):
+  # Socket Security: PostgreSQL is disabled by default (requires libpq).
+  o['variables']['node_use_postgres'] = b(options.with_postgres)
+
+def configure_iouring(o):
+  # Socket Security: io_uring is disabled by default (Linux only, requires liburing).
+  o['variables']['node_use_iouring'] = b(options.with_iouring)
+
+def configure_smol_tui(o):
+  # Socket Security: tui-infra + Yoga + node:smol-tui (default enabled).
+  o['variables']['node_use_smol_tui'] = b(not options.without_smol_tui)
 
 def configure_quic(o):
-  o['variables']['node_use_quic'] = b(options.experimental_quic and
-                                      not options.without_ssl)
+  # Socket Security: three independent QUIC stacks.
+  #
+  #   use_node_quic   gates upstream's src/quic/*.cc + deps/ngtcp2 + deps/nghttp3
+  #                   + node:quic builtin. Default off — files stay on disk but
+  #                   are excluded from the build graph.
+  #
+  #   use_smol_quic   gates packages/lsquic-infra (lsquic + ls-qpack) +
+  #                   node:smol-quic builtin. Default on.
+  #
+  #   use_smol_http3  gates the http3 binding glue + node:smol-http3 builtin.
+  #                   Default on. Requires use_smol_quic.
+  use_node_quic   = bool(options.with_node_quic or options.experimental_quic)
+  use_smol_quic   = not bool(options.without_smol_quic)
+  use_smol_http3  = not bool(options.without_smol_http3)
+  if use_smol_http3 and not use_smol_quic:
+    raise Exception(
+      '--without-smol-quic conflicts with --with-smol-http3 '
+      '(HTTP/3 requires QUIC). Pass --without-smol-http3 too.')
+  if options.without_ssl:
+    use_node_quic = use_smol_quic = use_smol_http3 = False
+  # Legacy node_use_quic stays in sync with node_use_node_quic so
+  # third-party gyp files keep working; node.gyp itself now gates on
+  # node_use_node_quic (paired wiring in the node.gyp source-list patch).
+  o['variables']['node_use_quic']       = b(use_node_quic)
+  o['variables']['node_use_node_quic']  = b(use_node_quic)
+  o['variables']['node_use_smol_quic']  = b(use_smol_quic)
+  o['variables']['node_use_smol_http3'] = b(use_smol_http3)
@@ -2802,6 +2832,9 @@
 configure_lief(output);
 configure_sqlite(output);
 configure_ffi(output);
+configure_postgres(output);
+configure_iouring(output);
+configure_smol_tui(output);
 configure_library('temporal_capi', output)
 configure_library('uvwasi', output)
 configure_library('zstd', output, pkgname='libzstd')
