# @node-versions: v26.1.0
# @description: Register every smol_* native binding in NODE_BUILTIN_BINDINGS
#
# Replaces wasi with smol_vfs in the standard binding macro and adds the
# full smol native binding set: smol_ffi, smol_http, smol_ilp,
# smol_manifest_native, smol_markdown, smol_postgres (conditional on
# HAVE_POSTGRES), smol_power, smol_primordial, smol_quic, smol_tui,
# smol_util, smol_versions_native, and smol_webstreams.
#
--- a/src/node_binding.cc
+++ b/src/node_binding.cc
@@ -94,7 +94,8 @@
   V(util)                                                                      \
   V(uv)                                                                        \
   V(v8)                                                                        \
-  V(wasi)                                                                      \
+  /* V(wasi) */                                                                \
+  V(smol_vfs)                                                                  \
   V(wasm_web_api)                                                              \
   V(watchdog)                                                                  \
   V(worker)                                                                    \
@@ -108,7 +109,20 @@
   NODE_BUILTIN_DEBUG_BINDINGS(V)                                               \
   NODE_BUILTIN_QUIC_BINDINGS(V)                                                \
   NODE_BUILTIN_SQLITE_BINDINGS(V)                                              \
-  NODE_BUILTIN_FFI_BINDINGS(V)
+  NODE_BUILTIN_POSTGRES_BINDINGS(V)                                            \
+  NODE_BUILTIN_FFI_BINDINGS(V)                                                 \
+  V(smol_ffi)                                                                  \
+  V(smol_http)                                                                 \
+  V(smol_ilp)                                                                  \
+  V(smol_manifest_native)                                                      \
+  V(smol_markdown)                                                             \
+  V(smol_power)                                                                \
+  V(smol_primordial)                                                           \
+  V(smol_quic)                                                                 \
+  V(smol_tui)                                                                  \
+  V(smol_util)                                                                 \
+  V(smol_versions_native)                                                      \
+  V(smol_webstreams)
 
 // This is used to load built-in bindings. Instead of using
 // __attribute__((constructor)), we call the _register_<modname>
