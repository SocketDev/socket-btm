{
  "name": "ink-builder",
  "version": "0.0.0",
  "description": "Prepatched Ink TUI framework with Socket-specific fixes — zero-dep ESM bundle (externals: react family only)",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/build/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mts",
    "clean": "node scripts/clean.mts",
    "cover": "vitest run --coverage",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=19.2.0"
  },
  "peerDependenciesMeta": {
    "react-devtools-core": {
      "optional": true
    }
  },
  "dependencies": {
    "@socketsecurity/lib-stable": "catalog:",
    "@socketsecurity/lib-stable": "catalog:",
    "build-infra": "workspace:*",
    "yoga-layout-builder": "workspace:*"
  },
  "devDependencies": {
    "@babel/parser": "7.26.3",
    "@babel/types": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "magic-string": "catalog:",
    "vitest": "catalog:"
  },
  "sources": {
    "ink": {
      "version": "7.0.0",
      "type": "git",
      "url": "https://github.com/vadimdemedes/ink.git",
      "ref": "fb14d811d513be19e5a57bb2faebbfd9ebd2f06a"
    }
  }
}
