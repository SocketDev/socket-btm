# @node-versions: v26.1.0
# @description: Add every smol_* binding to the external reference binding list
#
# Registers every Socket Security native binding in
# EXTERNAL_REFERENCE_BINDING_LIST so V8 snapshot building can resolve the
# external references. smol_postgres is guarded behind HAVE_POSTGRES since
# it is conditionally compiled.
#
# Files modified:
# - src/node_external_reference.h
#
--- a/src/node_external_reference.h
+++ b/src/node_external_reference.h
@@ -144,12 +144,49 @@ class ExternalReferenceRegistry {
 #define EXTERNAL_REFERENCE_BINDING_LIST_QUIC(V)
 #endif
 
+#if HAVE_POSTGRES
+#define EXTERNAL_REFERENCE_BINDING_LIST_POSTGRES(V) V(smol_postgres)
+#else
+#define EXTERNAL_REFERENCE_BINDING_LIST_POSTGRES(V)
+#endif
+
+// Socket Security: optional smol bindings that register V8 external references
+// (only ffi/http/ilp do). Gated on the same HAVE_SMOL_* defines as their sources
+// + builtin registration, so a trimmed build doesn't reference the excluded
+// register_external_reference_smol_X symbol.
+#if defined(HAVE_SMOL_FFI)
+#define EXTERNAL_REFERENCE_BINDING_LIST_SMOL_FFI(V) V(smol_ffi)
+#else
+#define EXTERNAL_REFERENCE_BINDING_LIST_SMOL_FFI(V)
+#endif
+#if defined(HAVE_SMOL_HTTP)
+#define EXTERNAL_REFERENCE_BINDING_LIST_SMOL_HTTP(V) V(smol_http)
+#else
+#define EXTERNAL_REFERENCE_BINDING_LIST_SMOL_HTTP(V)
+#endif
+#if defined(HAVE_SMOL_ILP)
+#define EXTERNAL_REFERENCE_BINDING_LIST_SMOL_ILP(V) V(smol_ilp)
+#else
+#define EXTERNAL_REFERENCE_BINDING_LIST_SMOL_ILP(V)
+#endif
+
 #define EXTERNAL_REFERENCE_BINDING_LIST(V)                                     \
   EXTERNAL_REFERENCE_BINDING_LIST_BASE(V)                                      \
   EXTERNAL_REFERENCE_BINDING_LIST_INSPECTOR(V)                                 \
   EXTERNAL_REFERENCE_BINDING_LIST_I18N(V)                                      \
   EXTERNAL_REFERENCE_BINDING_LIST_CRYPTO(V)                                    \
-  EXTERNAL_REFERENCE_BINDING_LIST_QUIC(V)
+  EXTERNAL_REFERENCE_BINDING_LIST_QUIC(V)                                      \
+  EXTERNAL_REFERENCE_BINDING_LIST_SMOL_FFI(V)                                  \
+  EXTERNAL_REFERENCE_BINDING_LIST_SMOL_HTTP(V)                                 \
+  EXTERNAL_REFERENCE_BINDING_LIST_SMOL_ILP(V)                                  \
+  V(smol_manifest_native)                                                      \
+  V(smol_power)                                                                \
+  V(smol_primordial)                                                           \
+  V(smol_util)                                                                 \
+  V(smol_versions_native)                                                      \
+  V(smol_vfs)                                                                  \
+  EXTERNAL_REFERENCE_BINDING_LIST_POSTGRES(V)                                  \
+  V(smol_webstreams)
 
 }  // namespace node
 
