    "./lib/sign": "./lib/sign.mts",
    "./lib/tarball-utils": "./lib/tarball-utils.mts",
    "./lib/test/helpers": "./lib/test/helpers.mts",
    "./lib/tool-downloader": "./lib/tool-downloader.mts",
    "./lib/tool-installer": "./lib/tool-installer.mts",
    "./lib/version-helpers": "./lib/version-helpers.mts",
