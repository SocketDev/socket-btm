{
  "name": "build-infra",
  "version": "0.0.0",
  "description": "Shared build infrastructure for building third-party dependencies from source",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./lib/build-env": "./lib/build-env.mts",
