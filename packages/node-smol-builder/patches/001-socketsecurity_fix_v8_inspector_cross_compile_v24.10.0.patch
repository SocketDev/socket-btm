# @node-versions: v24.10.0+
# @description: Fix v8_inspector_headers for cross-compilation
# @phase: 1
#
# This patch fixes "multiple rules generate" ninja errors when cross-compiling
# by conditionally including actions only when building for the host toolset.
#
# Error without this patch:
#   ninja: error: obj.host/tools/v8_gypfiles/v8_inspector_headers.ninja:26:
#   multiple rules generate gen/inspector-generated-output-root/src/js_protocol.stamp
#
# Root cause: When cross-compiling with toolsets: ['host', 'target'], GYP generates
# the actions for both toolsets, causing duplicate output files.
#
# Solution: Use GYP conditions to only include actions when _toolset=='host'.
# The generated files are in SHARED_INTERMEDIATE_DIR and used by both toolsets.

diff --git a/tools/v8_gypfiles/v8.gyp b/tools/v8_gypfiles/v8.gyp
index 32f00097..cde82572 100644
--- a/tools/v8_gypfiles/v8.gyp
+++ b/tools/v8_gypfiles/v8.gyp
@@ -1003,45 +1003,49 @@
           '<(inspector_generated_output_root)/include',
         ],
       },
-      'actions': [
-        {
-          'action_name': 'protocol_compatibility',
-          'inputs': [
-            '<(v8_inspector_js_protocol)',
-          ],
-          'outputs': [
-            '<@(inspector_generated_output_root)/src/js_protocol.stamp',
-          ],
-          'action': [
-            '<(python)',
-            '<(inspector_protocol_path)/check_protocol_compatibility.py',
-            '--stamp', '<@(_outputs)',
-            '<@(_inputs)',
-          ],
-          'message': 'Checking inspector protocol compatibility',
-        },
-        {
-          'action_name': 'protocol_generated_sources',
-          'inputs': [
-            '<(v8_inspector_js_protocol)',
-            '<(inspector_path)/inspector_protocol_config.json',
-            '<@(inspector_protocol_files)',
-          ],
-          'outputs': [
-            '<@(inspector_generated_sources)',
+      'conditions': [
+        ['_toolset=="host"', {
+          'actions': [
+            {
+              'action_name': 'protocol_compatibility',
+              'inputs': [
+                '<(v8_inspector_js_protocol)',
+              ],
+              'outputs': [
+                '<@(inspector_generated_output_root)/src/js_protocol.stamp',
+              ],
+              'action': [
+                '<(python)',
+                '<(inspector_protocol_path)/check_protocol_compatibility.py',
+                '--stamp', '<@(_outputs)',
+                '<@(_inputs)',
+              ],
+              'message': 'Checking inspector protocol compatibility',
+            },
+            {
+              'action_name': 'protocol_generated_sources',
+              'inputs': [
+                '<(v8_inspector_js_protocol)',
+                '<(inspector_path)/inspector_protocol_config.json',
+                '<@(inspector_protocol_files)',
+              ],
+              'outputs': [
+                '<@(inspector_generated_sources)',
+              ],
+              'process_outputs_as_sources': 1,
+              'action': [
+                '<(python)',
+                '<(inspector_protocol_path)/code_generator.py',
+                '--jinja_dir', '<(V8_ROOT)/third_party',
+                '--output_base', '<(inspector_generated_output_root)/src/inspector',
+                '--config', '<(inspector_path)/inspector_protocol_config.json',
+                '--config_value', 'protocol.path=<(v8_inspector_js_protocol)',
+                '--inspector_protocol_dir', '<(inspector_protocol_path)',
+              ],
+              'message': 'Generating inspector protocol sources from protocol json',
+            },
           ],
-          'process_outputs_as_sources': 1,
-          'action': [
-            '<(python)',
-            '<(inspector_protocol_path)/code_generator.py',
-            '--jinja_dir', '<(V8_ROOT)/third_party',
-            '--output_base', '<(inspector_generated_output_root)/src/inspector',
-            '--config', '<(inspector_path)/inspector_protocol_config.json',
-            '--config_value', 'protocol.path=<(v8_inspector_js_protocol)',
-            '--inspector_protocol_dir', '<(inspector_protocol_path)',
-          ],
-          'message': 'Generating inspector protocol sources from protocol json',
-        },
+        }],
       ],
     },  # v8_inspector_headers
     {
