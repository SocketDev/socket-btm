# @node-versions: v26.1.0
# @description: Fix GCC LTO linker, use ThinLTO for Clang/macOS, enable ARM64 branch protection, gold --icf=safe on Linux release, /OPT:REF+/OPT:ICF on Windows release
#
--- a/common.gypi
+++ b/common.gypi
@@ -189,7 +189,7 @@
               'MSVC_runtimeType': 2   # MultiThreadedDLL (/MD)
