# Build Node.js smol targeting glibc 2.17 (CentOS 7 / Amazon Linux 1 floor).
#
# GROUNDWORK ONLY — this file is NOT wired into any workflow yet. Build via:
#   depot build --project 8fpj9495vw --file packages/node-smol-builder/docker/Dockerfile.glibc-2.17 --platform linux/amd64 .
#   depot build --project 8fpj9495vw --file packages/node-smol-builder/docker/Dockerfile.glibc-2.17 --platform linux/arm64 .
#
# Base: pypa manylinux2014 — CentOS 7 vault + GCC 10 + glibc 2.17. Maintained
# by pypa (EOL 2027-05-04). The image comes as two separate arch-specific
# repositories (manylinux2014_x86_64, manylinux2014_aarch64) rather than a
# single multi-arch manifest, so we map TARGETARCH → repository suffix below.
#
# GCC 10 is too old for Node.js C++20 requirements. We layer Red Hat SCL
# `devtoolset-11` (GCC 11). devtoolset-11 is the HIGHEST SCL toolset on
# CentOS 7 vault — devtoolset-12/13/14 are only available on AlmaLinux 8
# and newer via gcc-toolset-*. GCC 11 supports enough C++20 for Node.js
# v25.x. SCL packages use the HOST glibc at runtime, so glibc stays 2.17
# while we get a modern compiler.
#
# The compat layer in src/socketsecurity/compat/glibc_compat.{h,cc} (patched in
# via 021-glibc-compat-layer.patch) wraps four symbols (__cxa_thread_atexit_impl,
# getrandom, quick_exit, at_quick_exit) so the resulting binary runs on glibc
# 2.17 even though we can rely on newer kernels at build time. See
# docs/plans/glibc-floor-lowering.md for the full plan.

ARG TARGETARCH

# manylinux2014_x86_64 and manylinux2014_aarch64 are DIFFERENT repositories,
# not a single multi-arch manifest. We select via TARGETARCH inside the FROM
# and pin both arches to the 2026-04-17 release. Bump both tags together so
# x64 and arm64 don't drift.
#
# Per-arch digests at pin time (quay.io/api/v1/repository/pypa/manylinux2014_*/tag/):
#   x86_64  2026.04.17-1 = sha256:96412a3110ba598851ba1cd9bfa66b74c2903bfec1af978f5e55def5f0f1912c
#   aarch64 2026.04.17-1 = sha256:2cfb8a1feca0f640b26689e27aadff0a8ff367243d2672a31207d075318d26c7
#
# Tag pinning rather than `FROM ... @sha256:` because Docker doesn't accept
# a digest suffix after a dynamic `${ARG}` substitution. pypa/manylinux
# policy is additive (they never mutate a dated tag), so tag pinning is
# effectively equivalent to digest pinning here. If a tag IS ever rewritten,
# the glibc tripwire later in this file will flag it.
FROM quay.io/pypa/manylinux2014_${TARGETARCH/amd64/x86_64}:2026.04.17-1 AS build

# Explicit cache-version tag from cache-versions.json; bumping this invalidates layers below.
ARG CACHE_VERSION=unset

# Socket-registry tool-checksums. Workflows `cp "$SOCKET_TOOL_CHECKSUMS_FILE"
# .build-context/registry-tools.json` before `docker build`, so this
# layer reads the same authoritative pnpm version + per-platform sha256
# that the setup action verified on the runner — no hardcoded SHA
# blocks in this Dockerfile. The file is gitignored; it materializes
# fresh for every CI run from socket-registry's pinned SHA.
COPY .build-context/registry-tools.json /tmp/registry-tools.json

# Install build dependencies.
# NOTE: manylinux2014 ships WITH SCL preconfigured — no `centos-release-scl`
# needed. If that package install ever appears necessary again, investigate
# why; don't paper over it with `|| true`, which silently masks real errors.
RUN yum -y install \
        git \
        curl \
        ccache \
        ninja-build \
        ca-certificates \
        xz-devel \
        openssl-devel \
        zlib-static \
        perl \
        zlib-devel \
        liburing-devel \
        jq \
        which \
        procps-ng \
        patch \
        devtoolset-11-gcc \
        devtoolset-11-gcc-c++ \
        devtoolset-11-libstdc++-devel \
        && \
    # Install Node.js from NodeSource.
    curl -fsSL https://rpm.nodesource.com/setup_current.x | bash - && \
    yum -y install nodejs && \
    ARCH=$(uname -m | sed 's/x86_64/x64/' | sed 's/aarch64/arm64/') && \
    PLATFORM="linux-${ARCH}" && \
    PNPM_VERSION=$(jq -r .pnpm.version /tmp/registry-tools.json) && \
    PNPM_ASSET=$(jq -r ".pnpm.checksums[\"${PLATFORM}\"].asset" /tmp/registry-tools.json) && \
    PNPM_SHA256=$(jq -r ".pnpm.checksums[\"${PLATFORM}\"].sha256" /tmp/registry-tools.json) && \
    curl -fsSL -o /tmp/pnpm.tar.gz "https://github.com/pnpm/pnpm/releases/download/v${PNPM_VERSION}/${PNPM_ASSET}" && \
    echo "${PNPM_SHA256}  /tmp/pnpm.tar.gz" | sha256sum -c - && \
    tar -xzf /tmp/pnpm.tar.gz -C /usr/local/bin && \
    rm /tmp/pnpm.tar.gz /tmp/registry-tools.json && \
    # Confirm we're actually on glibc 2.17. Build-time tripwire: if the base
    # image ever drifts or SCL accidentally links against a newer glibc, we
    # find out here, not in production.
    echo "Verifying glibc floor..." && \
    ldd --version | head -1 && \
    GLIBC_VER=$(ldd --version | head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1) && \
    echo "Detected glibc: $GLIBC_VER" && \
    [ "$GLIBC_VER" = "2.17" ] || (echo "× Expected glibc 2.17, got $GLIBC_VER" >&2 && exit 1) && \
    yum clean all

# Build static OpenSSL (manylinux2014 ships openssl-devel, but we build static
# for portability — same reasoning as the glibc 2.28 image).
COPY .github/scripts/build-static-openssl.sh .github/scripts/
RUN source /opt/rh/devtoolset-11/enable && .github/scripts/build-static-openssl.sh

# Set working directory.
WORKDIR /workspace

# Copy repository files.
COPY . .

# Install workspace dependencies.
ENV CI=true
RUN pnpm install --frozen-lockfile

# Build Node.js smol.
ARG BUILD_MODE=prod
ARG PLATFORM_ARCH=linux-x64
ARG MATRIX_PLATFORM=linux
ARG MATRIX_ARCH=x64
ENV BUILD_MODE=$BUILD_MODE
ENV PLATFORM_ARCH=$PLATFORM_ARCH
ENV MATRIX_PLATFORM=$MATRIX_PLATFORM
ENV MATRIX_ARCH=$MATRIX_ARCH
# Flag so compat/glibc_compat.cc knows we're targeting the 2.17 floor.
# (Currently informational; the wraps are version-tolerant anyway.)
ENV GLIBC_FLOOR=2.17

# Source devtoolset-11 environment before building.
# For amd64/x64 builds, set CFLAGS/CXXFLAGS to target baseline x86-64 without AVX/AVX2
# to ensure binary portability across different CPU generations.
RUN echo "Cache version: ${CACHE_VERSION}" && \
    source /opt/rh/devtoolset-11/enable && \
    if [ "$MATRIX_ARCH" = "x64" ]; then \
        export CFLAGS="$CFLAGS -march=x86-64 -mtune=generic" && \
        export CXXFLAGS="$CXXFLAGS -march=x86-64 -mtune=generic"; \
    fi && \
    if [ "$BUILD_MODE" = "prod" ]; then \
        pnpm --filter node-smol-builder build --prod --platform="${MATRIX_PLATFORM}" --arch="${MATRIX_ARCH}"; \
    else \
        pnpm --filter node-smol-builder build --dev --platform="${MATRIX_PLATFORM}" --arch="${MATRIX_ARCH}"; \
    fi

# Export stage: Copy build artifacts and checkpoints (not entire filesystem).
FROM scratch AS export
ARG BUILD_MODE=prod
COPY --from=build /workspace/packages/node-smol-builder/build /
