    "./lib/constants": "./lib/constants.mts",
    "./lib/emscripten-installer": "./lib/emscripten-installer.mts",
    "./lib/extraction-cache": "./lib/extraction-cache.mts",
    "./lib/github-error-utils": "./lib/github-error-utils.mts",
    "./lib/install-tools": "./lib/install-tools.mts",
    "./lib/libdeflate-init": "./lib/libdeflate-init.mts",
    "./lib/zstd-init": "./lib/zstd-init.mts",
    "./lib/onnx-helpers": "./lib/onnx-helpers.mts",
